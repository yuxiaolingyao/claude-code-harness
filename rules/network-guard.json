{
  "version": "1.0.0",
  "description": "Network address guard patterns — blocks metadata endpoints, SSRF targets, internal probes",
  "blocked_hosts": [
    "169.254.169.254",
    "metadata.google.internal",
    "metadata.google.internal.",
    "100.100.100.200",
    "instance-data.ec2.internal",
    "169.254.170.2",
    "kubernetes.default.svc",
    "metadata.tencentyun.com"
  ],
  "blocked_cidrs": [
    "169.254.0.0/16"
  ],
  "blocked_paths": [
    "/etc/passwd",
    "/etc/shadow",
    "/etc/hosts",
    "/proc/self/environ",
    "/proc/self/cmdline",
    "/proc/1/environ",
    "/var/run/docker.sock"
  ]
}
