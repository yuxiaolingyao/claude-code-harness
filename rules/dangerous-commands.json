{
  "version": "1.0.0",
  "description": "Command firewall rules — PreToolUse:Bash hook reads this file",
  "categories": {
    "destructive": {
      "description": "Irreversible destructive operations",
      "patterns": [
        "rm\\s+(-[a-z]*r[a-z]*f|-[a-z]*f[a-z]*r)\\s+/",
        "rm\\s+(-[a-z]*r\\s+-[a-z]*f|-[a-z]*f\\s+-[a-z]*r)\\s+/",
        "rm\\s+(--recursive.*--force|--force.*--recursive)\\s+/",
        "rm\\s+(-[a-z]*r[a-z]*f|-[a-z]*f[a-z]*r)\\s+~",
        "rm\\s+(-[a-z]*r[a-z]*f|-[a-z]*f[a-z]*r)\\s+\\$HOME",
        "git\\s+push\\s+.*(--force|-f)\\s+.*(main|master)",
        "git\\s+reset\\s+--hard",
        "git\\s+checkout\\s+--\\s+/",
        "git\\s+clean\\s+-[a-z]*f[a-z]*",
        ">\\s*/dev/sda",
        "mkfs\\.",
        "dd\\s+if=.*of=/dev/",
        "chmod\\s+777\\s+/",
        "chmod\\s+-R\\s+777\\s+/",
        "chown\\s+-R\\s+root\\s+/",
        "terraform\\s+destroy",
        "terraform\\s+apply\\s+.*-auto-approve",
        "kubectl\\s+delete\\s+namespace",
        "kubectl\\s+delete\\s+--all",
        "helm\\s+uninstall\\s+--no-hooks",
        "docker\\s+rm\\s+-f\\s+\\$\\(docker\\s+ps\\s+-aq\\)",
        "docker\\s+system\\s+prune\\s+-[a-z]*f[a-z]*",
        "drizzle-kit\\s+push[\\s:]*force",
        "DROP\\s+(TABLE|DATABASE|SCHEMA)",
        "TRUNCATE\\s+(TABLE\\s+)?",
        "sudo\\s+su\\s+-",
        "sudo\\s+rm\\s+-rf\\s+/",
        "fork\\s+bomb"
      ]
    },
    "credential-exfil": {
      "description": "Credential and secret exfiltration",
      "patterns": [
        "cat\\s+.*\\.env",
        "cat\\s+.*credentials",
        "cat\\s+.*\\.pem",
        "cat\\s+.*\\.key",
        "cat\\s+.*id_rsa",
        "cat\\s+~/\\.ssh/",
        "cat\\s+~/\\.aws/",
        "cat\\s+~/\\.gcp/",
        "cat\\s+~/\\.azure/",
        "cat\\s+~/\\.config/gcloud",
        "cat\\s+~/\\.netrc",
        "cat\\s+~/\\.gitconfig",
        "echo\\s+\\$.*KEY",
        "echo\\s+\\$.*TOKEN",
        "echo\\s+\\$.*SECRET",
        "echo\\s+\\$.*PASSWORD",
        "echo\\s+\\$.*CREDENTIAL",
        "printenv",
        "env\\s+\\|\\s*grep",
        "grep\\s+-r.*SECRET",
        "grep\\s+-r.*TOKEN",
        "grep\\s+-r.*PASSWORD",
        "history\\s*\\|",
        "aws\\s+configure\\s+get",
        "gcloud\\s+auth\\s+print",
        "gh\\s+auth\\s+token",
        "vault\\s+read",
        "op\\s+read"
      ]
    },
    "reverse-shell": {
      "description": "Reverse shells and remote code execution",
      "patterns": [
        "nc\\s+.*-e\\s+/bin/(ba)?sh",
        "nc\\s+.*-e\\s+/bin/(ba)?sh",
        "nc\\s+.*-c\\s+/bin/(ba)?sh",
        "/dev/tcp/.*/(ba)?sh",
        "bash\\s+-i\\s+>&\\s+/dev/tcp/",
        "bash\\s+-i\\s+>&\\s+/dev/udp/",
        "python.*socket\\.socket.*connect",
        "python.*subprocess.*\\.Popen",
        "python.*os\\.system.*nc",
        "python.*pty\\.spawn.*(/bin|/usr/bin)",
        "perl.*Socket.*connect",
        "perl.*exec.*(/bin/(ba)?sh|cmd)",
        "ruby.*TCPSocket.*exec",
        "ruby.*require.*socket.*spawn",
        "php.*fsockopen.*exec",
        "php.*exec.*nc",
        "lua.*socket\\.tcp.*execute",
        "nslookup.*\\$\\(.*\\)",
        "dig.*\\$\\(.*\\)",
        "socat.*exec:"
      ]
    },
    "encoding-bypass": {
      "description": "Encoding/obfuscation bypasses (CVE-2025-66032 coverage)",
      "patterns": [
        "base64\\s+(-d|--decode)",
        "base64\\s+.*\\|\\s*(ba)?sh",
        "xxd\\s+-r\\s+-p",
        "xxd\\s+-r\\s+.*\\|\\s*(ba)?sh",
        "openssl\\s+base64\\s+-d",
        "openssl\\s+enc\\s+-d",
        "python.*base64.*b64decode",
        "python.*codecs\\.decode.*base64",
        "python.*__import__.*os",
        "python.*eval\\(.*compile\\(",
        "python.*exec\\(.*\\)",
        "python\\s+-c\\s+.*import\\s+(os|subprocess|socket|pty|base64|codecs)",
        "perl\\s+-e\\s+.*(exec|system|qx|open\\s+pipe)",
        "ruby\\s+-e\\s+.*(exec|system|spawn|IO\\.popen|Open3)",
        "node\\s+-e\\s+.*(require.*child_process|exec|spawn)",
        "eval\\s+\\$\\(.*\\)",
        "eval\\s+\\$\\{.*\\}",
        "eval\\s+\\$[A-Z_]",
        "\\$\\(.*\\|\\s*base64)",
        "\\$\\(.*\\|\\s*xxd)",
        "echo\\s+.*\\|\\s*(ba)?sh\\b",
        "\\.\\s+/dev/stdin",
        "curl.*\\|\\s*(ba)?sh\\b",
        "wget.*-O\\s*-\\s*\\|\\s*(ba)?sh\\b",
        "curl.*\\|\\s*python",
        "curl.*\\|\\s*perl",
        "curl.*\\|\\s*ruby",
        "\\$\\(curl\\s+.*\\)"
      ]
    },
    "network-attack": {
      "description": "Internal network probing, metadata endpoints, SSRF",
      "patterns": [
        "169\\.254\\.169\\.254",
        "metadata\\.google\\.internal",
        "100\\.100\\.100\\.200",
        "curl.*169\\.254\\.169\\.254",
        "wget.*169\\.254\\.169\\.254",
        "curl.*metadata\\.google\\.internal",
        "nmap\\s+-",
        "masscan\\s+",
        "/etc/passwd",
        "/etc/shadow",
        "~\\/\\.ssh\\/authorized_keys",
        "/proc/self/environ",
        "SSRF",
        "ngrok\\s+tcp"
      ]
    },
    "supply-chain": {
      "description": "Supply chain attacks — suspicious registries and install sources",
      "patterns": [
        "pip\\s+install\\s+.*-i\\s+https?://",
        "pip\\s+install\\s+.*--index-url\\s+https?://",
        "pip\\s+install\\s+https?://",
        "pip\\s+install\\s+git\\+",
        "npm\\s+install\\s+.*--registry\\s+https?://",
        "npm\\s+install\\s+https?://",
        "npm\\s+install\\s+-g\\s+https?://",
        "gem\\s+install\\s+.*--source\\s+https?://",
        "curl.*\\|.*sh",
        "curl.*\\|.*bash",
        "wget.*-O\\s+.*\\|.*sh",
        "wget.*-O\\s+.*\\|.*bash"
      ]
    }
  }
}
