{
  "version": "1.0.0",
  "description": "Sensitive file path patterns — PreToolUse:Write|Edit hook reads this file",
  "patterns": [
    "\\.env$",
    "\\.env\\.",
    "credentials$",
    "credentials\\.(json|ya?ml|env|properties)$",
    "secret$",
    "\\.secret$",
    "secret\\.(ya?ml|json|env|properties|ini|toml)$",
    "secrets\\.(ya?ml|json)$",
    "\\.pem$",
    "\\.key$",
    "\\.pfx$",
    "\\.p12$",
    "\\.jks$",
    "\\.keystore$",
    "\\.truststore$",
    "id_rsa",
    "id_ed25519",
    "id_ecdsa",
    "identity$",
    "\\.netrc$",
    "\\.htpasswd$",
    "(^|/)config\\.json$",
    "\\.npmrc$",
    "\\.pypirc$",
    "\\.dockercfg$",
    "\\.docker/config\\.json$",
    "\\.git-credentials$",
    "\\.gitconfig$",
    "CRITICAL_RULES\\.md$",
    "~/\\.ssh/",
    "~/\\.aws/",
    "~/\\.gcp/",
    "~/\\.azure/",
    "~/\\.config/gcloud/"
  ]
}
