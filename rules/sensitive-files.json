{
  "version": "1.0.0",
  "description": "Sensitive file path patterns — PreToolUse:Write|Edit hook reads this file",
  "patterns": [
    "\\.env$",
    "\\.env\\.",
    "credentials",
    "secret",
    "\\.pem$",
    "\\.key$",
    "\\.pfx$",
    "\\.p12$",
    "\\.jks$",
    "\\.keystore$",
    "\\.truststore$",
    "id_rsa",
    "id_ed25519",
    "id_ecdsa",
    "identity$",
    "\\.netrc$",
    "\\.htpasswd$",
    "secrets\\.ya?ml$",
    "credentials\\.json$",
    "config\\.json$",
    "\\.npmrc$",
    "\\.pypirc$",
    "\\.dockercfg$",
    "\\.docker/config\\.json$",
    "\\.git-credentials$",
    "\\.gitconfig$",
    "CRITICAL_RULES\\.md$",
    "~/\\.ssh/",
    "~/\\.aws/",
    "~/\\.gcp/",
    "~/\\.azure/",
    "~/\\.config/gcloud/"
  ]
}
